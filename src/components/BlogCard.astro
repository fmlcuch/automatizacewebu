---
interface Props {
  title: string;
  description: string;
  publishDate: Date;
  image: string;
  imageAlt: string;
  href: string;
}

const { title, description, publishDate, image, imageAlt, href } = Astro.props;
const formattedDate = publishDate.toLocaleDateString("cs-CZ", {
  day: "numeric",
  month: "long",
  year: "numeric"
});
---

<article class="card-shell overflow-hidden">
  <a href={href} class="block">
    <img
      src={image}
      alt={imageAlt}
      class="aspect-[16/9] w-full object-cover"
      loading="lazy"
      width="800"
      height="450"
    />
  </a>
  <div class="p-6">
    <p class="text-sm text-slate-500">{formattedDate}</p>
    <h3 class="mt-3 text-2xl font-semibold text-slate-900">
      <a href={href} class="transition hover:text-brand">
        {title}
      </a>
    </h3>
    <p class="mt-4 text-base leading-7 text-slate-600">{description}</p>
    <a href={href} class="mt-6 inline-flex text-sm font-semibold text-brand transition hover:text-brand-dark">
      Přečíst článek
    </a>
  </div>
</article>
