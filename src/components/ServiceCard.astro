---
interface Props {
  title: string;
  description: string;
  price: string;
  href: string;
}

const { title, description, price, href } = Astro.props;
---

<article class="card-shell flex h-full flex-col p-6">
  <p class="text-sm font-semibold uppercase tracking-[0.2em] text-brand">Služba</p>
  <h3 class="mt-4 text-2xl font-semibold text-slate-900">{title}</h3>
  <p class="mt-4 flex-1 text-base leading-7 text-slate-600">{description}</p>
  <div class="mt-6 flex items-center justify-between gap-4 border-t border-slate-200 pt-6">
    <div>
      <p class="text-sm text-slate-500">Cena od</p>
      <p class="text-lg font-semibold text-slate-900">{price}</p>
    </div>
    <a href={href} class="btn-secondary">
      Detail služby
    </a>
  </div>
</article>
