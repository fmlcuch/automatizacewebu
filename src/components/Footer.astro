---
import { siteConfig } from "../data/site";

const year = new Date().getFullYear();

const navItems = [
  { href: "/", label: "Domů" },
  { href: "/sluzby", label: "Služby" },
  { href: "/blog", label: "Blog" },
  { href: "/kontakt", label: "Kontakt" },
  { href: "/ochrana-osobnich-udaju", label: "Zásady ochrany osobních údajů" }
];
---

<footer class="border-t border-slate-200 bg-slate-50">
  <div class="container-shell grid gap-10 py-14 md:grid-cols-[1.1fr_0.8fr_1fr]">
    <div class="space-y-4">
      <div class="flex items-center gap-3">
        <span
          class="flex h-11 w-11 items-center justify-center rounded-2xl bg-gradient-to-br from-indigo-600 to-brand text-lg font-bold text-white"
        >
          A
        </span>
        <div>
          <p class="font-semibold text-slate-900">automatizacewebu.cz</p>
          <p class="text-sm text-slate-500">Jednorázové automatizace pro WordPress, obsah a data</p>
        </div>
      </div>
      <p class="max-w-md text-sm leading-7 text-slate-600">
        Pomáháme firmám odstranit ruční práci kolem publikace obsahu, e-shopových dat a
        opakovaných administrativních úkonů bez dlouhých smluv a bez skrytých licenčních poplatků.
      </p>
    </div>

    <div>
      <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Navigace</p>
      <ul class="space-y-3">
        {navItems.map((item) => (
          <li>
            <a class="text-sm text-slate-600 transition hover:text-brand" href={item.href}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="space-y-4">
      <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Fakturační údaje</p>
      <div class="space-y-2 text-sm leading-7 text-slate-600">
        <p>{siteConfig.ownerName}</p>
        <p>IČO: {siteConfig.ico}</p>
        <p>Sídlo: {siteConfig.city}</p>
        <p>
          E-mail:
          <a href={`mailto:${siteConfig.email}`} class="text-brand hover:text-brand-dark">
            {siteConfig.email}
          </a>
        </p>
      </div>
      <p class="rounded-2xl border border-blue-100 bg-white p-4 text-sm leading-7 text-slate-600">
        U jednorázových služeb neplatíte žádné měsíční licenční poplatky navíc. Cena zahrnuje práci,
        AI kredity i potřebné provozní náklady dle konkrétní služby.
      </p>
    </div>
  </div>

  <div class="border-t border-slate-200">
    <div class="container-shell flex flex-col gap-2 py-6 text-sm text-slate-500 md:flex-row md:items-center md:justify-between">
      <p>&copy; {year} {siteConfig.ownerName}. Všechna práva vyhrazena.</p>
      <p>Bez závazků. Transparentní ceny. Rychlé dodání.</p>
    </div>
  </div>
</footer>