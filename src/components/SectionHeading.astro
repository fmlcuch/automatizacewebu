---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
}

const { eyebrow, title, description, align = "left" } = Astro.props;
const alignment = align === "center" ? "mx-auto text-center" : "";
---

<div class:list={["max-w-3xl", alignment]}>
  {eyebrow && (
    <p class="mb-4 text-sm font-semibold uppercase tracking-[0.2em] text-brand">{eyebrow}</p>
  )}
  <h2 class="text-3xl font-bold text-slate-900 md:text-4xl">{title}</h2>
  {description && <p class="mt-5 text-lg leading-8 text-slate-600">{description}</p>}
</div>
