---
interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<article class="card-shell p-6">
  <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-brand-soft text-xl text-brand">
    {icon}
  </div>
  <h3 class="mt-5 text-xl font-semibold text-slate-900">{title}</h3>
  <p class="mt-3 text-base leading-7 text-slate-600">{description}</p>
</article>
