---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
  primaryHref: string;
  primaryLabel: string;
  secondaryHref: string;
  secondaryLabel: string;
  highlights: string[];
}

const { eyebrow, title, description, primaryHref, primaryLabel, secondaryHref, secondaryLabel, highlights } =
  Astro.props;
---

<section class="section-shell bg-hero-grid">
  <div class="container-shell grid items-center gap-10 lg:grid-cols-[1.15fr_0.85fr]">
    <div class="max-w-3xl">
      <p class="mb-5 inline-flex rounded-full border border-blue-100 bg-white px-4 py-2 text-sm font-medium text-brand shadow-sm">
        {eyebrow}
      </p>
      <h1 class="text-balance text-4xl font-bold tracking-tight text-slate-900 md:text-6xl">
        {title}
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-600">{description}</p>

      <div class="mt-8 flex flex-col gap-4 sm:flex-row">
        <a href={primaryHref} class="btn-primary">
          {primaryLabel}
        </a>
        <a href={secondaryHref} class="btn-secondary">
          {secondaryLabel}
        </a>
      </div>
    </div>

    <aside class="card-shell overflow-hidden bg-white">
      <div class="border-b border-slate-200 bg-slate-50 px-6 py-5">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Co získáte</p>
      </div>
      <ul class="space-y-4 px-6 py-6">
        {highlights.map((item) => (
          <li class="flex items-start gap-3">
            <span class="mt-1 inline-flex h-6 w-6 flex-none items-center justify-center rounded-full bg-brand-soft text-brand">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m5 13 4 4L19 7"></path>
              </svg>
            </span>
            <span class="text-sm leading-7 text-slate-600">{item}</span>
          </li>
        ))}
      </ul>
    </aside>
  </div>
</section>
