---
import Layout from "../layouts/Layout.astro";

const nextSteps = [
  {
    title: "Analýza vašeho zadání",
    description: "Podíváme se na váš web, zhodnotíme popsaný problém a odhadneme přibližný rozsah práce."
  },
  {
    title: "Návrh řešení do e-mailu",
    description: "Do 24 hodin vám pošleme e-mail s potvrzením, návrhem konkrétního postupu a přesnou kalkulací."
  },
  {
    title: "Bezpečné spuštění",
    description: "Teprve až si vše odsouhlasíme, požádáme vás o vytvoření přístupu a pustíme se do práce."
  }
];
---

<Layout
  title="Děkujeme za poptávku | automatizacewebu.cz"
  description="Vaše poptávka byla úspěšně přijata. Ozveme se vám do 24 hodin s návrhem dalšího postupu."
  canonical="/dekujeme"
  noindex={true}
>
  <section class="section-shell bg-hero-grid min-h-[70vh] flex items-center">
    <div class="container-shell max-w-5xl">
      <div class="grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
        
        <!-- Levá strana: Hlavní sdělení -->
        <div class="max-w-xl">
          <div class="inline-flex items-center gap-2 rounded-full bg-blue-50 px-4 py-1.5 text-sm font-medium text-brand mb-6 border border-blue-100">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
            Poptávka byla úspěšně odeslána
          </div>
          
          <h1 class="text-balance text-4xl font-bold tracking-tight text-slate-900 md:text-5xl">
            Děkujeme za zájem. Všechno je na dobré cestě.
          </h1>
          
          <p class="mt-6 text-lg leading-8 text-slate-600">
            Vaše data jsme v pořádku přijali. Nyní se na vaše zadání podíváme a navrhneme ten nejefektivnější postup automatizace. Nemusíte nic dál vyplňovat, vše podstatné vyřešíme e-mailem.
          </p>
          
          <div class="mt-10 flex flex-col gap-4 sm:flex-row">
            <a href="/sluzby" class="btn-primary">Prohlédnout nabídku služeb</a>
            <a href="/" class="btn-secondary">Zpět na úvod</a>
          </div>
        </div>

        <!-- Pravá strana: Co se bude dít dál (Ujištění klienta) -->
        <div class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-sm md:p-8">
          <h2 class="text-xl font-bold text-slate-900 mb-6">Co bude následovat?</h2>
          
          <div class="space-y-6">
            {nextSteps.map((step, index) => (
              <div class="flex gap-4">
                <span class="mt-0.5 inline-flex h-7 w-7 flex-none items-center justify-center rounded-full bg-brand-soft text-sm font-bold text-brand">
                  {index + 1}
                </span>
                <div>
                  <h3 class="font-semibold text-slate-900 text-base">{step.title}</h3>
                  <p class="mt-1 text-sm leading-6 text-slate-500">{step.description}</p>
                </div>
              </div>
            ))}
          </div>

          <div class="mt-8 border-t border-slate-100 pt-6 text-center">
            <p class="text-xs text-slate-400">
              ⚡ Odpovídáme obvykle do 24 hodin (v pracovní dny).
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>