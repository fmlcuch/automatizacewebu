---
import { getCollection } from "astro:content";
import BlogCard from "../../components/BlogCard.astro";
import CTASection from "../../components/CTASection.astro";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<Layout
  title="Blog o automatizaci WordPressu a provozu webu | automatizacewebu.cz"
  description="Praktické články o automatizaci obsahu, SEO metadat, WordPress workflow a propojení systémů pomocí Make.com."
  canonical="/blog"
>
  <section class="section-shell bg-hero-grid">
    <div class="container-shell max-w-4xl">
      <p class="mb-5 text-sm font-semibold uppercase tracking-[0.2em] text-brand">Blog</p>
      <h1 class="text-balance text-4xl font-bold tracking-tight text-slate-900 md:text-6xl">
        Praktické články o automatizaci obsahu, WordPressu a provozu webu.
      </h1>
      <p class="mt-6 text-lg leading-8 text-slate-600">
        Krátké a konkrétní texty pro firmy, které chtějí méně ruční práce, lepší kvalitu dat a
        jasnější procesy kolem správy webu.
      </p>
    </div>
  </section>

  <section class="section-shell">
    <div class="container-shell">
      <div class="grid gap-6 lg:grid-cols-3">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            publishDate={post.data.publishDate}
            image={post.data.image}
            imageAlt={post.data.imageAlt}
            href={`/blog/${post.slug}`}
          />
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Chcete podobnou automatizaci i pro váš web?"
    description="Podíváme se na váš WordPress, e-shop nebo obsahový proces a navrhneme, kde dává automatizace největší smysl."
    primaryHref="/kontakt"
    primaryLabel="Poptat automatizaci"
    secondaryHref="/sluzby"
    secondaryLabel="Zobrazit služby"
  />
</Layout>
