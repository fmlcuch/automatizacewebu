---
import { getCollection } from "astro:content";
import BenefitCard from "../components/BenefitCard.astro";
import BlogCard from "../components/BlogCard.astro";
import CTASection from "../components/CTASection.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ServiceCard from "../components/ServiceCard.astro";
import Layout from "../layouts/Layout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const latestPosts = posts.slice(0, 3);

const services = [
  {
    title: "Oprava diakritiky",
    description: "Hromadná kontrola a oprava textů ve WordPressu. Zbavte se chybějících háčků, překlepů a sjednoťte tón komunikace napříč webem.",
    price: "4 900 Kč",
    href: "/sluzby/oprava-diakritiky"
  },
  {
    title: "AI prolinkování",
    description: "Automatické propojování starších článků s novými pro okamžité posílení vnitřního SEO a lepší indexaci na vyhledávačích.",
    price: "5 900 Kč",
    href: "/sluzby/ai-prolinkovani"
  },
  {
    title: "SEO metadata",
    description: "Automatické doplnění chytlavých meta popisků a klíčových slov přímo do vašeho Yoast, Rank Math nebo AIOSEO pluginu.",
    price: "2 000 Kč",
    href: "/sluzby/seo-metadata"
  },
  {
    title: "ALT texty",
    description: "Chytrý vizuální popis obrázků pro výrazně vyšší návštěvnost z Google Obrázků a stoprocentní pořádek v galerii médií.",
    price: "2 000 Kč",
    href: "/sluzby/alt-texty"
  },
  {
    title: "AI analytik",
    description: "Pravidelný pondělní report do e-mailu. Lidsky psané shrnutí návštěvnosti s konkrétními tipy na zlepšení byznysu.",
    price: "2 000 Kč / měsíc",
    href: "/sluzby/ai-analytik"
  },
  {
    title: "Propojení systémů",
    description: "Jednoúčelová integrace. Propojte bezpečně formuláře, objednávky či kontakty z WordPressu s vaším CRM nebo účetnictvím.",
    price: "9 900 Kč",
    href: "/sluzby/propojeni-systemu"
  }
];

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "automatizacewebu.cz",
    "url": "https://automatizacewebu.cz/",
    "inLanguage": "cs-CZ"
  },
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "automatizacewebu.cz",
    "url": "https://automatizacewebu.cz/",
    "image": "https://automatizacewebu.cz/og-image.jpg",
    "description": "Chytrá automatizace rutinní práce kolem WordPressu, obsahu a dat bez drahých agenturních paušálů.",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "CZ"
    },
    "priceRange": "CZK 2000 - CZK 9900"
  }
];
---

<Layout
  title="Automatizace WordPressu, obsahu a dat | automatizacewebu.cz"
  description="Pomáháme firmám zautomatizovat rutinní procesy kolem WordPressu, e-shopových dat a správy obsahu. Rychle, bezpečně a bez měsíčních paušálů."
  canonical="/"
  schema={schemas}
>
  <Hero
    eyebrow="Chytrá automatizace procesů"
    title="Osvoboďte svůj tým od rutinní práce kolem WordPressu a e-shopových dat"
    description="Dodáváme pevně vymezená automatizovaná řešení s jasným rozsahem, fixní cenou a rychlým spuštěním. Bez zdlouhavých IT projektů, skrytých licencí a měsíčních agenturních paušálů."
    primaryHref="/kontakt"
    primaryLabel="Poptat řešení"
    secondaryHref="/sluzby"
    secondaryLabel="Zobrazit nabídku"
    highlights={[
      "Chytré integrace dat a automatická optimalizace webového obsahu.",
      "Maximální bezpečí – přístupy předáváte formou nativní pozvánky.",
      "Spuštění a otestování celého řešení typicky do 3 pracovních dnů.",
      "Transparentní koncové ceny včetně provozu systému a AI kreditů."
    ]}
  />

  <section class="section-shell">
    <div class="container-shell">
      <SectionHeading
        eyebrow="Naše filozofie"
        title="Řešení navržená pro okamžitý výsledek bez zdlouhavých schůzek."
        description="Neprodáváme hodiny obecných konzultací ani složité analýzy. Dodáváme hotové balíčky, které okamžitě odstraní ruční rutinu z vašeho každodenního provozu."
        align="center"
      />

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        <BenefitCard
          icon="⏱"
          title="Okamžitá úspora času"
          description="Odstraníte zdlouhavé ruční přepisování objednávek, administrativní doplňování SEO popisků nebo zdlouhavé opravování stovek textů."
        />
        <BenefitCard
          icon="💳"
          title="Transparentní fixní ceny"
          description="U všech našich služeb přesně víte, kolik zaplatíte. Žádné natahování hodinových sazeb ani skryté průběžné poplatky."
        />
        <BenefitCard
          icon="⚡"
          title="Blesková implementace"
          description="Díky připraveným procesům dokážeme většinu automatizací převzít, bezpečně nastavit a otestovat v řádu několika dnů."
        />
      </div>
    </div>
  </section>

  <section class="section-shell bg-surface">
    <div class="container-shell">
      <SectionHeading
        eyebrow="Jak to funguje"
        title="Jednoduchý proces postavený na efektivitě"
        description="Každý krok je navržený tak, aby minimálně zatěžoval váš provozní, marketingový i manažerský tým."
      />

      <ol class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-4 list-none p-0">
        {[
          {
            step: "01",
            title: "Zvolíte si oblast",
            description: "Vyberete si z našich hotových balíčků podle toho, která ruční činnost na webu váš tým aktuálně nejvíc zdržuje a zatěžuje."
          },
          {
            step: "02",
            title: "Nezávazná poptávka",
            description: "Vyplníte krátký formulář. Během 24 hodin vám zašleme e-mailem přesný návrh postupu a finální fixní kalkulaci."
          },
          {
            step: "03",
            title: "Bezpečné propojení",
            description: "Po odsouhlasení nás jednoduše pozvete do administrace svého WordPressu jako nového uživatele. Žádné sdílení vašich hesel."
          },
          {
            step: "04",
            title: "Předání a spuštění",
            description: "Systém kompletně nastavíme, důkladně otestujeme a předáme vám funkční řešení s garantovaným bezproblémovým chodem."
          }
        ].map((item) => (
          <li class="card-shell p-6 bg-white rounded-xl shadow-sm">
            <p class="text-sm font-bold tracking-[0.2em] text-brand" aria-hidden="true">{item.step}</p>
            <h3 class="mt-4 text-xl font-semibold text-slate-900">{item.title}</h3>
            <p class="mt-3 text-base leading-7 text-slate-600">{item.description}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section-shell">
    <div class="container-shell">
      <SectionHeading
        eyebrow="Katalog řešení"
        title="Vyberte si konkrétní automatizaci podle vašich aktuálních potřeb."
        description="Každá specializovaná služba obsahuje garantovaný rozsah, transparentní cenový model a FAQ pro rychlé rozhodování."
      />

      <div class="mt-12 grid gap-6 lg:grid-cols-2 xl:grid-cols-3">
        {services.map((service) => (
          <ServiceCard {...service} />
        ))}
      </div>
    </div>
  </section>

  <section class="section-shell bg-surface">
    <div class="container-shell">
      <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
        <SectionHeading
          eyebrow="Know-how"
          title="Praktické tipy pro automatizaci a efektivní správu webu."
          description="Žádná teoretická omáčka. Pouze konkrétní návody a postupy, jak odstranit ruční práci a zlepšit kvalitu dat i obsahu."
        />
        <a href="/blog" class="btn-secondary">
          Zobrazit všechny články
        </a>
      </div>

      <div class="mt-12 grid gap-6 lg:grid-cols-3">
        {latestPosts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            publishDate={post.data.publishDate}
            image={post.data.image}
            imageAlt={post.data.imageAlt}
            href={`/blog/${post.slug}`}
          />
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Máte na webu konkrétní úkon, který vás už nebaví dělat ručně?"
    description="Popište nám ho stručně vlastními slovy. Obratem posoudíme, zda je vhodný pro automatizaci, a navrhneme vám nejrychlejší cestu k trvalé úspoře času."
    primaryHref="/kontakt"
    primaryLabel="Nezávazně poptat"
    secondaryHref="/sluzby"
    secondaryLabel="Prohlédnout všechny služby"
  />
</Layout>