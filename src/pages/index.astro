---
import { getCollection } from "astro:content";
import BenefitCard from "../components/BenefitCard.astro";
import BlogCard from "../components/BlogCard.astro";
import CTASection from "../components/CTASection.astro";
import Hero from "../components/Hero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ServiceCard from "../components/ServiceCard.astro";
import Layout from "../layouts/Layout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const latestPosts = posts.slice(0, 3);

const services = [
  {
    title: "Oprava diakritiky",
    description: "Vyčištění článků, stránek i produktů od chybějící diakritiky, překlepů a stylové roztříštěnosti.",
    price: "4 900 Kč",
    href: "/sluzby/oprava-diakritiky"
  },
  {
    title: "SEO metadata",
    description: "Hromadné doplnění meta description a klíčových štítků přímo do vašeho SEO pluginu ve WordPressu.",
    price: "2 000 Kč",
    href: "/sluzby/seo-metadata"
  },
  {
    title: "ALT texty",
    description: "Automatické doplnění popisů obrázků pro lepší dohledatelnost i přístupnost webu.",
    price: "2 000 Kč",
    href: "/sluzby/alt-texty"
  },
  {
    title: "AI analytik",
    description: "Pravidelný e-mail s lidsky čitelným souhrnem návštěvnosti a doporučením dalších kroků.",
    price: "2 000 Kč / měsíc",
    href: "/sluzby/ai-analytik"
  },
  {
    title: "Propojení systémů",
    description: "Jedno konkrétní Make.com napojení mezi WordPressem a dalším systémem bez zbytečné složitosti.",
    price: "9 900 Kč",
    href: "/sluzby/propojeni-systemu"
  }
];

const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "automatizacewebu.cz",
    url: "https://automatizacewebu.cz/",
    inLanguage: "cs-CZ"
  }
];
---

<Layout
  title="Automatizace WordPressu, obsahu a dat | automatizacewebu.cz"
  description="Pomáháme firmám automatizovat rutinní práci kolem WordPressu, obsahu a dat bez drahých agentur a měsíčních licencí."
  canonical="/"
  schema={schemas}
>
  <Hero
    eyebrow="Automatizace bez zbytečné režie"
    title="Pomáháme firmám automatizovat rutinní práci kolem WordPressu, obsahu a dat."
    description="Dodáme konkrétní službu s jasným rozsahem, cenou a termínem. Bez drahých agentur, bez skrytých licencí a bez zbytečné technické omáčky."
    primaryHref="/kontakt"
    primaryLabel="Poptat automatizaci"
    secondaryHref="/sluzby"
    secondaryLabel="Zobrazit služby"
    highlights={[
      "Jednorázové i průběžné automatizace pro WordPress a WooCommerce.",
      "Bezpečné předání přístupů přes šifrovaný formulář po potvrzení objednávky.",
      "Nasazení typicky do 3 pracovních dnů podle rozsahu služby.",
      "Ceny zahrnují AI kredity i provozní náklady dle nabídky."
    ]}
  />

  <section class="section-shell">
    <div class="container-shell">
      <SectionHeading
        eyebrow="Proč s námi"
        title="Služby navržené tak, aby rychle odstranily ruční práci."
        description="Neprodáváme obecné konzultace. Dodáváme přesně vymezené automatizace, které mají jasný výstup, cenu a termín."
        align="center"
      />

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        <BenefitCard
          icon="⏱"
          title="Úspora času"
          description="Odstraníte opakovanou ruční práci při úpravách textů, doplňování metadat nebo přepisování dat mezi systémy."
        />
        <BenefitCard
          icon="💳"
          title="Žádné skryté poplatky"
          description="U jednorázových služeb platíte pevně danou cenu. Žádné nepřehledné hodinovky ani další licence bokem."
        />
        <BenefitCard
          icon="⚡"
          title="Rychlé nasazení"
          description="Většinu služeb umíme převzít, zpracovat a vrátit v průběhu několika dnů od uhrazení a dodání přístupů."
        />
      </div>
    </div>
  </section>

  <section class="section-shell bg-surface">
    <div class="container-shell">
      <SectionHeading
        eyebrow="Jak to funguje"
        title="Jednoduchý proces bez zbytečných schůzek."
        description="Každý krok je navržený tak, aby byl srozumitelný pro marketing, provoz i majitele firmy."
      />

      <div class="mt-12 grid gap-6 md:grid-cols-2 xl:grid-cols-4">
        {[
          {
            step: "01",
            title: "Vyberete službu",
            description: "Podíváte se na detail služby, cenu a rozsah. Pokud si nejste jistí, ozvete se přes formulář."
          },
          {
            step: "02",
            title: "Odešlete objednávku",
            description: "Vyplníte krátký formulář přímo na landing page služby bez složitého schvalování a zbytečného čekání."
          },
          {
            step: "03",
            title: "Předáte přístupy bezpečně",
            description: "Po potvrzení objednávky vám případně pošleme zabezpečený postup pro předání přístupů k WordPressu nebo dalším nástrojům."
          },
          {
            step: "04",
            title: "Hotovo do 3 dnů",
            description: "Po převzetí podkladů službu zpracujeme a vrátíme s jasným výstupem nebo spuštěnou automatizací."
          }
        ].map((item) => (
          <article class="card-shell p-6">
            <p class="text-sm font-semibold tracking-[0.2em] text-brand">{item.step}</p>
            <h3 class="mt-4 text-xl font-semibold text-slate-900">{item.title}</h3>
            <p class="mt-3 text-base leading-7 text-slate-600">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-shell">
    <div class="container-shell">
      <SectionHeading
        eyebrow="Služby"
        title="Vyberte si konkrétní automatizaci podle toho, co vás dnes nejvíc brzdí."
        description="Každá služba má vlastní landing page s přesným rozsahem, cenou, FAQ a objednávkou přes formulář."
      />

      <div class="mt-12 grid gap-6 lg:grid-cols-2 xl:grid-cols-3">
        {services.map((service) => (
          <ServiceCard {...service} />
        ))}
      </div>
    </div>
  </section>

  <section class="section-shell bg-surface">
    <div class="container-shell">
      <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
        <SectionHeading
          eyebrow="Blog"
          title="Nejnovější články o automatizaci WordPressu a provozu webu."
          description="Krátké, praktické texty pro firmy, které chtějí odstranit ruční práci a zlepšit kvalitu webového obsahu."
        />
        <a href="/blog" class="btn-secondary">
          Všechny články
        </a>
      </div>

      <div class="mt-12 grid gap-6 lg:grid-cols-3">
        {latestPosts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            publishDate={post.data.publishDate}
            image={post.data.image}
            imageAlt={post.data.imageAlt}
            href={`/blog/${post.slug}`}
          />
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Chcete odstranit jednu konkrétní ruční činnost z vašeho webu?"
    description="Popište nám problém, který vás nejvíc zdržuje. Ozveme se s doporučením nejvhodnější služby nebo navrhneme jednoduchý postup."
    primaryHref="/kontakt"
    primaryLabel="Nezávazně poptat"
    secondaryHref="/sluzby"
    secondaryLabel="Projít všechny služby"
  />
</Layout>
