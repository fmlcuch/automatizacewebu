---
import CTASection from "../../components/CTASection.astro";
import Layout from "../../layouts/Layout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import ServiceOrderForm from "../../components/ServiceOrderForm.astro";
const pageUrl = "/sluzby/alt-texty";

const faq = [
  {
    question: "Jaké typy obrázků umíte popsat?",
    answer: "Typicky jde o produktové fotografie z e-shopů, ilustrační obrázky v článcích, bannerové vizuály i zcela běžné fotografie volně nahrané v galerii vašeho WordPressu."
  },
  {
    question: "Zapíšete vygenerovaný ALT text rovnou do WordPressu?",
    answer: "Ano, vše je 100% automatizované. Výstup standardně zapisujeme přímo do pole „Alternativní text“ ve vaší WordPress knihovně médií."
  },
  {
    question: "Pracuje systém při generování i s klíčovými slovy?",
    answer: "Ano. Popisy nejsou náhodné ani generické. Cílem AI je vytvořit přirozené ALT texty, které perfektně odpovídají obsahu konkrétní stránky a dávají smysl i z pohledu SEO dohledatelnosti."
  }
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Automatické doplnění ALT textů ve WordPressu",
  name: "ALT texty",
  description:
    "Vizuální AI analyzuje obrázky ve WordPressu a doplní relevantní alternativní texty pro lepší SEO přímo do knihovny médií.",
  provider: {
    "@type": "Organization",
    name: "automatizacewebu.cz",
    url: "https://automatizacewebu.cz"
  },
  offers: {
    "@type": "AggregateOffer",
    priceCurrency: "CZK",
    lowPrice: "2000",
    url: `https://automatizacewebu.cz${pageUrl}`
  }
};
---

<Layout
  title="ALT texty pro WordPress obrázky | automatizacewebu.cz"
  description="Doplníme relevantní ALT texty do WordPress galerie pomocí vizuální AI a zapíšeme je rovnou do knihovny médií."
  canonical={pageUrl}
  schema={serviceSchema}
>
  <section class="section-shell bg-hero-grid">
    <div class="container-shell grid gap-10 lg:grid-cols-[1fr_360px]">
      <div class="max-w-3xl">
        <p class="mb-5 text-sm font-semibold uppercase tracking-[0.2em] text-brand">Služba</p>
        <h1 class="text-balance text-4xl font-bold tracking-tight text-slate-900 md:text-6xl">
          ALT texty pro WordPress galerii bez ručního dopisování
        </h1>
        <p class="mt-6 text-lg leading-8 text-slate-600">
          Google samotné obrázky nevidí, čte pouze jejich popisky. Pokud máte galerii plnou prázdných políček nebo obrázků s názvem
          IMG_4829.jpg, zbytečně přicházíte o organické zákazníky i lepší hodnocení přístupnosti webu.
        </p>
        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a href="#objednavka" class="btn-primary">Objednat službu</a>
          <a href="/kontakt" class="btn-secondary">Nejdřív se zeptat</a>
        </div>
      </div>

      <aside class="card-shell p-6">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Cena</p>
        <div class="mt-5 space-y-4">
          <div class="rounded-2xl bg-slate-50 p-4">
            <p class="text-sm text-slate-500">Jednotková cena</p>
            <p class="mt-1 text-2xl font-semibold text-slate-900">4 Kč / obrázek</p>
          </div>
          <div class="rounded-2xl bg-slate-50 p-4">
            <p class="text-sm text-slate-500">Příklad z praxe</p>
            <p class="mt-1 text-lg font-semibold text-slate-900">1 000 obrázků = 4 000 Kč</p>
          </div>
          <div class="rounded-2xl border border-blue-100 bg-blue-50 p-4 text-sm leading-7 text-slate-700">
            Minimální hodnota jedné objednávky: <strong>2 000 Kč</strong>.
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section-shell">
    <div class="container-shell grid gap-12 lg:grid-cols-2">
      <div>
        <SectionHeading
          eyebrow="Problém zákazníka"
          title="Galerie plná obrázků, u kterých WordPressu chybí využitelný ALT text."
          description="Ruční doplňování SEO popisků u stovek obrázků je zdlouhavé a často končí u nečitelných technických názvů souborů. Takový výsledek nepomáhá ani dohledatelnosti na Google, ani přístupnosti webu pro zrakově znevýhodněné."
        />
      </div>
      <div class="card-shell p-6">
        <h2 class="text-2xl font-semibold text-slate-900">Co služba řeší</h2>
        <ul class="mt-5 space-y-4 text-base leading-7 text-slate-600">
          <li>Vizuální umělá inteligence přesně rozpozná, co je na každém obrázku skutečně vyobrazené.</li>
          <li>Vytvoří naprosto relevantní alternativní text s ohledem na obsah a celkový kontext vašeho webu.</li>
          <li>Zapisuje všechny výstupy okamžitě a přímo do políčka Alternativní text uvnitř WordPressu.</li>
          <li>Ušetří vám desítky až stovky hodin nudné rutinní práce s proklikáváním vaší knihovny médií.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section-shell bg-surface">
    <div class="container-shell grid gap-6 lg:grid-cols-2">
      <article class="card-shell p-6">
        <h2 class="text-2xl font-semibold text-slate-900">Co jako zákazník dostanete</h2>
        <ul class="mt-5 space-y-4 text-base leading-7 text-slate-600">
          <li>Kompletní a bezchybnou analýzu celé vaší galerie, nebo jen vámi vybraného vzorku obrázků.</li>
          <li>Relevantní a SEO optimalizované ALT texty, zapsané rovnou do databáze WordPressu.</li>
          <li>Chytré popisy okamžitě použitelné pro výrazně lepší dohledatelnost a přístupnost webu.</li>
          <li>Jasnou a transparentní cenu účtovanou pouze za skutečný počet zpracovaných obrázků.</li>
        </ul>
      </article>
      <article class="card-shell p-6">
        <h2 class="text-2xl font-semibold text-slate-900">Proč zvolit toto řešení</h2>
        <ul class="mt-5 space-y-4 text-base leading-7 text-slate-600">
          <li>Férová cena placená po kusech bez jakýchkoliv skrytých či měsíčních agenturních příplatků.</li>
          <li>Žádné dlouhodobé závazky ani nutnost platit si předražené licence na SEO nástroje.</li>
          <li>Bleskové dávkové zpracování a "vyčištění" i těch nejrozsáhlejších e-shopových galerií.</li>
          <li>Veškeré kredity pro umělou inteligenci a provoz systému jsou již plně zahrnuté v ceně služby.</li>
        </ul>
      </article>
    </div>
  </section>

  <ServiceOrderForm serviceName="ALT texty" sourcePage={pageUrl} />

  <section class="section-shell">
    <div class="container-shell">
      <SectionHeading eyebrow="FAQ" title="Časté otázky" />
      <div class="mt-10 space-y-4">
        {faq.map((item) => (
          <details class="card-shell p-6">
            <summary class="cursor-pointer list-none text-lg font-semibold text-slate-900">
              {item.question}
            </summary>
            <p class="mt-4 text-base leading-7 text-slate-600">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Máte dlouho neudržovanou galerii a chcete ji rychle vyčistit?"
    description="Napište nám celkový objem médií nebo pošlete odkaz na web. Obratem vám potvrdíme, zda je pro vás vhodnější dávkové zpracování nebo pilotní testovací vzorek."
    primaryHref="#objednavka"
    primaryLabel="Objednat službu"
    secondaryHref="/kontakt"
    secondaryLabel="Položit dotaz"
  />
</Layout>