---
import CTASection from "../../components/CTASection.astro";
import Layout from "../../layouts/Layout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import ServiceOrderForm from "../../components/ServiceOrderForm.astro";
const pageUrl = "/sluzby/seo-metadata/";

const faq = [
  {
    question: "Do kterých pluginů umíte metadata automaticky zapisovat?",
    answer: "Standardně a nejraději pracujeme s pluginy Yoast SEO, Rank Math a All in One SEO. Pokud používáte jiný plugin, prověříme jeho kompatibilitu ještě před začátkem práce."
  },
  {
    question: "Musím vám dodat tabulku s klíčovými slovy?",
    answer: "Nemusíte. Služba zahrnuje inteligentní analýzu obsahu každé jednotlivé stránky nebo produktu, ze kterého AI sama vytáhne 3 až 5 nejrelevantnějších klíčových slov a na jejich základě text sestaví."
  },
  {
    question: "Pro koho je tato služba primárně vhodná?",
    answer: "Typicky pro firemní weby, magazíny a e-shopy, které mají větší množství stránek nebo produktů a nechtějí ztrácet dny až týdny ručním dopisováním SEO popisků."
  }
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Hromadná tvorba SEO metadat ve WordPressu",
  name: "SEO metadata",
  description:
    "Automatická analýza obsahu, vytažení klíčových slov a vygenerování meta popisků s vysokou mírou prokliku pro stránky i produkty včetně zápisu do SEO pluginu.",
  provider: {
    "@type": "Organization",
    name: "automatizacewebu.cz",
    url: "https://automatizacewebu.cz"
  },
  offers: {
    "@type": "AggregateOffer",
    priceCurrency: "CZK",
    lowPrice: "2000",
    url: `https://automatizacewebu.cz${pageUrl}`
  }
};
---

<Layout
  title="SEO metadata pro WordPress a e-shop | automatizacewebu.cz"
  description="Vytvoříme meta popisky a klíčové štítky pro stránky nebo produkty a automaticky je propíšeme do vašeho SEO pluginu."
  canonical={`${pageUrl}/`}
  schema={serviceSchema}
>
  <section class="section-shell bg-hero-grid">
    <div class="container-shell grid gap-10 lg:grid-cols-[1fr_360px]">
      <div class="max-w-3xl">
        <p class="mb-5 text-sm font-semibold uppercase tracking-[0.2em] text-brand">Služba</p>
        <h1 class="text-balance text-4xl font-bold tracking-tight text-slate-900 md:text-6xl">
          SEO metadata pro weby a e-shopy bez ručního přepisování
        </h1>
        <p class="mt-6 text-lg leading-8 text-slate-600">
          Zvyšte okamžitě proklikovost z vyhledávačů bez stovek hodin nudné práce. Umělá inteligence si "přečte" váš obsah a vytvoří
          unikátní popisky, které lákají zákazníky ke kliknutí.
        </p>
        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a href="#objednavka" class="btn-primary">Objednat službu</a>
          <a href="/kontakt/" class="btn-secondary">Nejdřív se zeptat</a>
        </div>
      </div>

      <aside class="card-shell p-6">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Cena</p>
        <div class="mt-5 space-y-4">
          <div class="rounded-2xl bg-slate-50 p-4">
            <p class="text-sm text-slate-500">Jednotková cena</p>
            <p class="mt-1 text-2xl font-semibold text-slate-900">6 Kč / produkt nebo stránka</p>
          </div>
          <div class="rounded-2xl bg-slate-50 p-4">
            <p class="text-sm text-slate-500">Příklad z praxe</p>
            <p class="mt-1 text-lg font-semibold text-slate-900">400 produktů = 2 400 Kč</p>
            <p class="mt-2 text-sm leading-6 text-slate-600">Kompletně na klíč včetně všech licencí a poplatků za umělou inteligenci.</p>
          </div>
          <div class="rounded-2xl border border-blue-100 bg-blue-50 p-4 text-sm leading-7 text-slate-700">
            Minimální hodnota jedné objednávky: <strong>2 000 Kč</strong>.
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section-shell">
    <div class="container-shell grid gap-12 lg:grid-cols-2">
      <div>
        <SectionHeading
          eyebrow="Problém zákazníka"
          title="Obsah na webu sice existuje, ale ve výsledcích vyhledávání nepůsobí přesvědčivě."
          description="Ruční psaní SEO popisků je pomalé a u větších katalogů prakticky nereálné. Výsledkem bývají buď prázdná pole, zkopírované duplicitní texty, nebo vyhledávačem náhodně vytvořený a nečitelný úryvek textu."
        />
      </div>
      <div class="card-shell p-6">
        <h2 class="text-2xl font-semibold text-slate-900">Co služba řeší</h2>
        <ul class="mt-5 space-y-4 text-base leading-7 text-slate-600">
          <li>AI si pozorně přečte a pochopí obsah každé vybrané stránky nebo produktu.</li>
          <li>Automaticky vytáhne 3 až 5 nejvíce relevantních klíčových slov a SEO štítků.</li>
          <li>Vygeneruje chytlavý meta description (popisek) v ideální povolené délce.</li>
          <li>Vše bleskově zapíše přímo do políček ve vašem Yoastu, Rank Math nebo AIOSEO pluginu.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section-shell bg-surface">
    <div class="container-shell grid gap-6 lg:grid-cols-2">
      <article class="card-shell p-6">
        <h2 class="text-2xl font-semibold text-slate-900">Co jako zákazník dostanete</h2>
        <ul class="mt-5 space-y-4 text-base leading-7 text-slate-600">
          <li>Okamžité hromadné zpracování celého e-shopu nebo blogu.</li>
          <li>Meta popisky profesionálně napsané pro vyšší míru prokliku (CTR) z Google.</li>
          <li>Klíčová slova vytažená přímo z reálného obsahu bez vašeho zásahu.</li>
          <li>Přímý zápis dat do WordPress databáze bez vaší další ruční administrativy.</li>
        </ul>
      </article>
      <article class="card-shell p-6">
        <h2 class="text-2xl font-semibold text-slate-900">Proč zvolit toto řešení</h2>
        <ul class="mt-5 space-y-4 text-base leading-7 text-slate-600">
          <li>Platíte transparentní cenu pouze za zpracované kusy, žádné drahé hodinové sazby.</li>
          <li>Vše je bez závazků a bez nutnosti platit agentuře další měsíční paušály.</li>
          <li>Rychlé dodání a zpracování i u katalogů s desítkami tisíc produktů.</li>
          <li>Celý systém běží bezpečně a pod plnou kontrolou.</li>
        </ul>
      </article>
    </div>
  </section>

  <ServiceOrderForm serviceName="SEO metadata" sourcePage={pageUrl} />

  <section class="section-shell">
    <div class="container-shell">
      <SectionHeading eyebrow="FAQ" title="Časté otázky" />
      <div class="mt-10 space-y-4">
        {faq.map((item) => (
          <details class="card-shell p-6">
            <summary class="cursor-pointer list-none text-lg font-semibold text-slate-900">
              {item.question}
            </summary>
            <p class="mt-4 text-base leading-7 text-slate-600">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Máte stovky produktů a nechcete už metadata řešit ručně?"
    description="Službu umíme nasadit i na ty největší e-shopy. Pošlete nám nezávaznou poptávku a obratem vám naceníme řešení."
    primaryHref="#objednavka"
    primaryLabel="Objednat službu"
    secondaryHref="/kontakt/"
    secondaryLabel="Položit dotaz"
  />
</Layout>
