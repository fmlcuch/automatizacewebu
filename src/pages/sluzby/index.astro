---
import CTASection from "../../components/CTASection.astro";
import Layout from "../../layouts/Layout.astro";
import ServiceCard from "../../components/ServiceCard.astro";

const services = [
  {
    title: "Oprava diakritiky",
    description: "AI kontrola a oprava textů ve WordPressu. Zbavte se chybějících háčků, překlepů a sjednoťte tón komunikace napříč webem.",
    price: "od 4 900 Kč",
    href: "/sluzby/oprava-diakritiky"
  },
  {
    title: "AI prolinkování",
    description: "Automatické propojování starších článků s novými pro okamžité posílení vnitřního SEO a lepší indexaci na Google.",
    price: "5 900 Kč",
    href: "/sluzby/ai-prolinkovani"
  },
  {
    title: "SEO metadata",
    description: "Automatické doplnění chytlavých meta popisků a klíčových slov přímo do vašeho Yoast, Rank Math nebo AIOSEO pluginu.",
    price: "od 2 000 Kč",
    href: "/sluzby/seo-metadata"
  },
  {
    title: "ALT texty",
    description: "Chytrý vizuální popis obrázků pro lepší dohledatelnost na Googlu a pořádek v galerii médií.",
    price: "od 2 000 Kč",
    href: "/sluzby/alt-texty"
  },
  {
    title: "AI analytik",
    description: "Pravidelný pondělní report do e-mailu. Lidsky psané shrnutí návštěvnosti s konkrétními tipy na zlepšení webu.",
    price: "2 000 Kč / měsíc",
    href: "/sluzby/ai-analytik"
  },
  {
    title: "Propojení systémů",
    description: "Jednoúčelová integrace. Propojte bezpečně formuláře, objednávky či kontakty z WordPressu s vaším CRM nebo účetnictvím.",
    price: "9 900 Kč",
    href: "/sluzby/propojeni-systemu"
  }
];

// Dynamické generování Schema.org pro katalog služeb (ItemList)
const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Služby automatizace webu",
  "description": "Přehled hotových služeb pro automatizaci WordPressu, obsahu a dat.",
  "url": "https://automatizacewebu.cz/sluzby",
  "itemListElement": services.map((service, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": service.title,
    "description": service.description,
    "url": `https://automatizacewebu.cz${service.href}`
  }))
};
---

<Layout
  title="Služby automatizace pro WordPress a data | automatizacewebu.cz"
  description="Přehled hotových služeb pro firmy: opravy textů, AI prolinkování, SEO metadata, ALT texty, analytické reporty a integrace."
  canonical="/sluzby/"
  schema={schema}
>
  <section class="section-shell bg-hero-grid">
    <div class="container-shell max-w-4xl">
      <p class="mb-5 text-sm font-semibold uppercase tracking-[0.2em] text-brand">Služby</p>
      <h1 class="text-balance text-4xl font-bold tracking-tight text-slate-900 md:text-6xl">
        Hotové služby s jasným rozsahem, cenou a rychlým spuštěním.
      </h1>
      <p class="mt-6 text-lg leading-8 text-slate-600">
        Vyberte si službu podle typu problému. Každá stránka obsahuje detail výstupu, transparentní cenový
        model, časté dotazy i přímé objednání přes formulář.
      </p>
    </div>
  </section>

  <section class="section-shell">
    <div class="container-shell">
      <h2 class="sr-only">Katalog nabízených automatizací</h2>
      
      <div class="grid gap-6 lg:grid-cols-2 xl:grid-cols-3">
        {services.map((service) => (
          <ServiceCard {...service} />
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Nejste si jistí, kterou službu zvolit?"
    description="Napište nám stručně, co vás dnes na webu zdržuje. Doporučíme nejvhodnější variantu nebo kombinaci kroků."
    primaryHref="/kontakt"
    primaryLabel="Poslat poptávku"
    secondaryHref="/blog/"
    secondaryLabel="Inspirujte se na blogu"
  />
</Layout>
