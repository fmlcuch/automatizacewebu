---
import CTASection from "../../components/CTASection.astro";
import Layout from "../../layouts/Layout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import ServiceOrderForm from "../../components/ServiceOrderForm.astro";
const pageUrl = "/sluzby/propojeni-systemu/";

const faq = [
  {
    question: "Jaké typy propojení obvykle řešíte?",
    answer: "Typicky jde o automatické odesílání formulářů z webu do sdílených tabulek, přenos objednávek do fakturačního systému nebo synchronizaci nových kontaktů do CRM. Zaměřujeme se vždy na jedno jasně vymezené datové workflow."
  },
  {
    question: "Je v ceně zahrnutý i samotný provoz integrace?",
    answer: "Ano. Jednorázová cena 9 900 Kč zahrnuje technickou implementaci, otestování a kompletní provoz celého propojení na prvních 12 měsíců."
  },
  {
    question: "Kolik stojí další rok provozu?",
    answer: "Následující roky se platí pouze provozní a udržovací poplatek 1 500 Kč ročně, pokud chcete integraci i nadále využívat. Žádné další skryté poplatky neúčtujeme."
  }
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Jednorázové propojení WordPressu s dalším systémem",
  name: "Propojení systémů",
  description:
    "Analýza a automatizované propojení WordPressu nebo WooCommerce s jedním dalším systémem včetně ročního provozu na klíč.",
  provider: {
    "@type": "Organization",
    name: "automatizacewebu.cz",
    url: "https://automatizacewebu.cz"
  },
  offers: {
    "@type": "Offer",
    priceCurrency: "CZK",
    price: "9900",
    url: `https://automatizacewebu.cz${pageUrl}`
  }
};
---

<Layout
  title="Propojení WordPressu s dalšími systémy | automatizacewebu.cz"
  description="Postavíme jedno konkrétní datové propojení mezi WordPressem nebo WooCommerce a vaším dalším systémem bez zbytečné složitosti."
  canonical={`${pageUrl}/`}
  schema={serviceSchema}
>
  <section class="section-shell bg-hero-grid">
    <div class="container-shell grid gap-10 lg:grid-cols-[1fr_360px]">
      <div class="max-w-3xl">
        <p class="mb-5 text-sm font-semibold uppercase tracking-[0.2em] text-brand">Služba</p>
        <h1 class="text-balance text-4xl font-bold tracking-tight text-slate-900 md:text-6xl">
          Jednoúčelové propojení WordPressu s vaším systémem
        </h1>
        <p class="mt-6 text-lg leading-8 text-slate-600">
          Potřebujete vyřešit jednu konkrétní rutinu, která vám denně bere čas? Přesně na to je
          tahle služba. Zprovozníme bezpečné propojení dvou systémů bez nutnosti programovat velký IT projekt a bez zbytečných funkcí navíc.
        </p>
        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a href="#objednavka" class="btn-primary">Objednat službu</a>
          <a href="/kontakt/" class="btn-secondary">Nejdřív se zeptat</a>
        </div>
      </div>

      <aside class="card-shell p-6">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Cena</p>
        <div class="mt-5 space-y-4">
          <div class="rounded-2xl bg-slate-50 p-4">
            <p class="text-sm text-slate-500">Jedno propojení</p>
            <p class="mt-1 text-2xl font-semibold text-slate-900">9 900 Kč</p>
          </div>
          <div class="rounded-2xl bg-slate-50 p-4 text-sm leading-7 text-slate-600">
            Cena zahrnuje nasazení a provoz integrace na prvních 12 měsíců.
          </div>
          <div class="rounded-2xl border border-blue-100 bg-blue-50 p-4 text-sm leading-7 text-slate-700">
            Další rok provozu: <strong>1 500 Kč / rok</strong> (udržovací poplatek).
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section-shell">
    <div class="container-shell grid gap-12 lg:grid-cols-2">
      <div>
        <SectionHeading
          eyebrow="Problém zákazníka"
          title="Jedna opakovaná ruční činnost zdržuje tým každý den."
          description="Formuláře se musí ručně přepisovat do sdílených tabulek, objednávky se po jedné přenáší do fakturace a kontakty zbytečně končí v několika nespojených nástrojích."
        />
      </div>
      <div class="card-shell p-6">
        <h2 class="text-2xl font-semibold text-slate-900">Co služba řeší</h2>
        <ul class="mt-5 space-y-4 text-base leading-7 text-slate-600">
          <li>Zanalyzujeme jeden konkrétní proces, který dnes děláte ručně.</li>
          <li>Bezpečně propojíme WordPress nebo WooCommerce s jedním dalším systémem.</li>
          <li>Ošetříme tok dat tak, aby vše fungovalo naprosto stabilně a spolehlivě.</li>
          <li>Okamžitě odstraníme opakovaný administrativní krok z vašeho každodenního provozu.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section-shell bg-surface">
    <div class="container-shell grid gap-6 lg:grid-cols-2">
      <article class="card-shell p-6">
        <h2 class="text-2xl font-semibold text-slate-900">Co zákazník dostane</h2>
        <ul class="mt-5 space-y-4 text-base leading-7 text-slate-600">
          <li>Analýzu a technický návrh jednoho konkrétního propojení.</li>
          <li>Kompletní implementaci automatizovaného workflow.</li>
          <li>Spuštěnou a otestovanou integraci s provozem zahrnutým na 12 měsíců.</li>
          <li>Jasně vymezený rozsah projektu bez rizika, že se úpravy skrytě prodraží.</li>
        </ul>
      </article>
      <article class="card-shell p-6">
        <h2 class="text-2xl font-semibold text-slate-900">Proč zvolit toto řešení</h2>
        <ul class="mt-5 space-y-4 text-base leading-7 text-slate-600">
          <li>Jednorázová cena a předem přesně známý rozsah práce.</li>
          <li>Žádné dlouhodobé závazky ani vysoké měsíční agenturní paušály.</li>
          <li>První rok kompletního provozu integrace je již zahrnut v ceně.</li>
          <li>Extrémně rychlé dodání u běžných integračních scénářů.</li>
        </ul>
      </article>
    </div>
  </section>

  <ServiceOrderForm serviceName="Propojení systémů" sourcePage={pageUrl} />

  <section class="section-shell">
    <div class="container-shell">
      <SectionHeading eyebrow="FAQ" title="Časté otázky" />
      <div class="mt-10 space-y-4">
        {faq.map((item) => (
          <details class="card-shell p-6">
            <summary class="cursor-pointer list-none text-lg font-semibold text-slate-900">
              {item.question}
            </summary>
            <p class="mt-4 text-base leading-7 text-slate-600">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Máte jednu konkrétní ruční operaci, která už vás nebaví?"
    description="Popište nám ji. Okamžitě ověříme, zda je vhodná pro jednorázové propojení v rámci této dostupné služby."
    primaryHref="#objednavka"
    primaryLabel="Objednat službu"
    secondaryHref="/kontakt/"
    secondaryLabel="Položit dotaz"
  />
</Layout>
