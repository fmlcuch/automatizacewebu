---
import CTASection from "../../components/CTASection.astro";
import Layout from "../../layouts/Layout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import ServiceOrderForm from "../../components/ServiceOrderForm.astro";
const pageUrl = "/sluzby/propojeni-systemu";

const faq = [
  {
    question: "Jaké typy propojení řešíte?",
    answer: "Typicky formuláře do Google Tabulek, objednávky do fakturačního systému nebo kontakty do CRM. Zaměřujeme se na jedno jasně vymezené workflow."
  },
  {
    question: "Je v ceně i provoz?",
    answer: "Ano. Cena 9 900 Kč zahrnuje implementaci i provoz integrace na prvních 12 měsíců."
  },
  {
    question: "Kolik stojí další rok?",
    answer: "Další rok se platí jen udržovací poplatek 1 500 Kč ročně, pokud chcete integraci ponechat v provozu."
  }
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Jednorázové propojení WordPressu s dalším systémem přes Make.com",
  name: "Propojení systémů",
  description:
    "Analýza a propojení WordPressu nebo WooCommerce s jedním dalším systémem přes Make.com včetně ročního provozu.",
  provider: {
    "@type": "Organization",
    name: "automatizacewebu.cz",
    url: "https://automatizacewebu.cz"
  },
  offers: {
    "@type": "Offer",
    priceCurrency: "CZK",
    price: "9900",
    url: `https://automatizacewebu.cz${pageUrl}`
  }
};
---

<Layout
  title="Propojení WordPressu s dalšími systémy | automatizacewebu.cz"
  description="Postavíme jedno konkrétní Make.com propojení mezi WordPressem nebo WooCommerce a dalším systémem bez zbytečné složitosti."
  canonical={pageUrl}
  schema={serviceSchema}
>
  <section class="section-shell bg-hero-grid">
    <div class="container-shell grid gap-10 lg:grid-cols-[1fr_360px]">
      <div class="max-w-3xl">
        <p class="mb-5 text-sm font-semibold uppercase tracking-[0.2em] text-brand">Služba</p>
        <h1 class="text-balance text-4xl font-bold tracking-tight text-slate-900 md:text-6xl">
          Jedno účelové propojení WordPressu s dalším systémem
        </h1>
        <p class="mt-6 text-lg leading-8 text-slate-600">
          Potřebujete vyřešit jednu jedinou otravnou věc, která vám denně bere čas? Přesně na to je
          tahle služba. Bez velkého IT projektu a bez zbytečných funkcí navíc.
        </p>
        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a href="#objednavka" class="btn-primary">Objednat službu</a>
          <a href="/kontakt" class="btn-secondary">Nejdřív se zeptat</a>
        </div>
      </div>

      <aside class="card-shell p-6">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Cena</p>
        <div class="mt-5 space-y-4">
          <div class="rounded-2xl bg-slate-50 p-4">
            <p class="text-sm text-slate-500">Jedno propojení</p>
            <p class="mt-1 text-2xl font-semibold text-slate-900">9 900 Kč</p>
          </div>
          <div class="rounded-2xl bg-slate-50 p-4 text-sm leading-7 text-slate-600">
            Cena zahrnuje provoz integrace na prvních 12 měsíců.
          </div>
          <div class="rounded-2xl border border-blue-100 bg-blue-50 p-4 text-sm leading-7 text-slate-700">
            Další rok: <strong>1 500 Kč / rok</strong> jako udržovací poplatek.
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section-shell">
    <div class="container-shell grid gap-12 lg:grid-cols-2">
      <div>
        <SectionHeading
          eyebrow="Problém zákazníka"
          title="Jedna opakovaná ruční činnost zdržuje tým každý den."
          description="Formuláře se přepisují do tabulek, objednávky se ručně přenáší do fakturace a kontakty končí v několika nespojených nástrojích."
        />
      </div>
      <div class="card-shell p-6">
        <h2 class="text-2xl font-semibold text-slate-900">Co služba řeší</h2>
        <ul class="mt-5 space-y-4 text-base leading-7 text-slate-600">
          <li>Analyzuje jeden konkrétní proces, který dnes děláte ručně.</li>
          <li>Propojí WordPress nebo WooCommerce s jedním dalším systémem přes Make.com.</li>
          <li>Ošetří tok dat tak, aby fungoval stabilně a srozumitelně.</li>
          <li>Odstraní opakovaný administrativní krok z každodenního provozu.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section-shell bg-surface">
    <div class="container-shell grid gap-6 lg:grid-cols-2">
      <article class="card-shell p-6">
        <h2 class="text-2xl font-semibold text-slate-900">Co zákazník dostane</h2>
        <ul class="mt-5 space-y-4 text-base leading-7 text-slate-600">
          <li>Analýzu a návrh jednoho konkrétního propojení.</li>
          <li>Implementaci workflow přes Make.com.</li>
          <li>Spuštěnou integraci s provozem zahrnutým na 12 měsíců.</li>
          <li>Jasně vymezený rozsah bez bobtnání projektu do dalších úprav.</li>
        </ul>
      </article>
      <article class="card-shell p-6">
        <h2 class="text-2xl font-semibold text-slate-900">Trust prvky</h2>
        <ul class="mt-5 space-y-4 text-base leading-7 text-slate-600">
          <li>Jednorázová cena a předem známý rozsah.</li>
          <li>Bez závazků a bez měsíčních agenturních paušálů.</li>
          <li>První rok provozu je v ceně.</li>
          <li>Rychlé dodání u standardních integračních scénářů.</li>
        </ul>
      </article>
    </div>
  </section>

  <ServiceOrderForm serviceName="Propojení systémů" sourcePage={pageUrl} />

  <section class="section-shell">
    <div class="container-shell">
      <SectionHeading eyebrow="FAQ" title="Časté otázky" />
      <div class="mt-10 space-y-4">
        {faq.map((item) => (
          <details class="card-shell p-6">
            <summary class="cursor-pointer list-none text-lg font-semibold text-slate-900">
              {item.question}
            </summary>
            <p class="mt-4 text-base leading-7 text-slate-600">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Máte jednu konkrétní ruční operaci, která už vás nebaví?"
    description="Popište ji a ověříme, zda je vhodná pro jednorázové propojení v rámci této služby."
    primaryHref="#objednavka"
    primaryLabel="Objednat službu"
    secondaryHref="/kontakt"
    secondaryLabel="Položit dotaz"
  />
</Layout>
