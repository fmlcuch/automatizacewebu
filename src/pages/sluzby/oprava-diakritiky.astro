---
import CTASection from "../../components/CTASection.astro";
import Layout from "../../layouts/Layout.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import ServiceOrderForm from "../../components/ServiceOrderForm.astro";
const pageUrl = "/sluzby/oprava-diakritiky";

const faq = [
  {
    question: "Co přesně se počítá jako jedna stránka?",
    answer: "Počítáme každou unikátní URL adresu, na které budeme texty opravovat – tedy jeden konkrétní článek na blogu, jednu podstránku (např. O nás) nebo jeden detail produktu ve WooCommerce. Krátké popisky rubrik či kategorií vám k balíčku opravíme zdarma."
  },
  {
    question: "Opravujete čistě jen diakritiku?",
    answer: "Ne. Součástí automatizovaného procesu je i hromadná oprava překlepů, vyčištění základního slovosledu a plošné sjednocení stylu komunikace tak, aby web působil po zásahu zcela konzistentně."
  },
  {
    question: "Jak probíhá předání podkladů a webu?",
    answer: "Ihned po odeslání objednávky vám e-mailem potvrdíme další postup. Nejčastěji nám bezpečně pošlete přístupy přes šifrovaný formulář, nebo se s vaším vývojářem domluvíme na exportu databáze či XML souboru."
  }
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Oprava diakritiky a jazykové sjednocení obsahu ve WordPressu",
  name: "Oprava diakritiky",
  description:
    "Kompletní analýza textů, inteligentní oprava diakritiky, překlepů, slovosledu a sjednocení tónu komunikace napříč WordPress obsahem.",
  provider: {
    "@type": "Organization",
    name: "automatizacewebu.cz",
    url: "https://automatizacewebu.cz"
  },
  offers: {
    "@type": "AggregateOffer",
    priceCurrency: "CZK",
    lowPrice: "4900",
    url: `https://automatizacewebu.cz${pageUrl}`
  }
};
---

<Layout
  title="Oprava diakritiky a textů ve WordPressu | automatizacewebu.cz"
  description="AI projde celý váš WordPress obsah, opraví chybějící diakritiku, překlepy i styl komunikace a vrátí web do reprezentativního stavu."
  canonical={pageUrl}
  schema={serviceSchema}
>
  <section class="section-shell bg-hero-grid">
    <div class="container-shell grid gap-10 lg:grid-cols-[1fr_360px]">
      <div class="max-w-3xl">
        <p class="mb-5 text-sm font-semibold uppercase tracking-[0.2em] text-brand">Služba</p>
        <h1 class="text-balance text-4xl font-bold tracking-tight text-slate-900 md:text-6xl">
          Oprava diakritiky a sjednocení textů ve WordPressu
        </h1>
        <p class="mt-6 text-lg leading-8 text-slate-600">
          Máte e-shop po starém hromadném importu, zmateném překladu nebo texty od deseti různých autorů? Naše systémy
          projdou celou databázi WordPressu a dají vaše texty zpět do perfektního a čtivého stavu.
        </p>
        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a href="#objednavka" class="btn-primary">Objednat službu</a>
          <a href="/kontakt" class="btn-secondary">Nejdřív se zeptat</a>
        </div>
      </div>

      <aside class="card-shell p-6">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-500">Cenový model</p>
        <div class="mt-5 space-y-4">
          <div class="rounded-2xl bg-slate-50 p-4">
            <p class="text-sm text-slate-500">Do 100 stránek / produktů</p>
            <p class="mt-1 text-2xl font-semibold text-slate-900">4 900 Kč</p>
            <p class="mt-2 text-sm leading-6 text-slate-600">Fixní startovací balíček včetně veškerých licencí a AI kreditů.</p>
          </div>
          <div class="rounded-2xl bg-slate-50 p-4">
            <p class="text-sm text-slate-500">Nad 100 stránek / produktů</p>
            <p class="mt-1 text-2xl font-semibold text-slate-900">49 Kč / kus</p>
          </div>
          <div class="rounded-2xl border border-blue-100 bg-blue-50 p-4 text-sm leading-7 text-slate-700">
            Minimální hodnota jedné objednávky: <strong>4 900 Kč</strong>.
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section-shell">
    <div class="container-shell grid gap-12 lg:grid-cols-2">
      <div>
        <SectionHeading
          eyebrow="Problém zákazníka"
          title="Web dělá firmě ostudu a působí neprofesionálně, i když obsahově dává smysl."
          description="Chybějící diakritika, nejednotný styl psaní a drobné gramatické chyby zbytečně snižují důvěryhodnost celého webu v očích návštěvníků. Ručně to čistit zabere stovky hodin času a spoustu peněz."
        />
      </div>
      <div class="card-shell p-6">
        <h2 class="text-2xl font-semibold text-slate-900">Co služba řeší</h2>
        <ul class="mt-5 space-y-4 text-base leading-7 text-slate-600">
          <li>Automaticky vyhledá a opraví chybějící diakritiku ve starších importech i v ručně vkládaném obsahu.</li>
          <li>Inteligentně vyčistí překlepy a opraví základní stylistické či gramatické nedostatky.</li>
          <li>Sjednotí tón komunikace (Tone of Voice), aby web náhodně nepřeskakoval mezi tykáním a vykáním.</li>
          <li>Vrátí veškerý obsah do reprezentativního stavu, za který se nebudete stydět a můžete ho dál rozvíjet.</li>
        </ul>
      </div>
    </div>
  </section>

  <section class="section-shell bg-surface">
    <div class="container-shell grid gap-6 lg:grid-cols-2">
      <article class="card-shell p-6">
        <h2 class="text-2xl font-semibold text-slate-900">Co jako zákazník dostanete</h2>
        <ul class="mt-5 space-y-4 text-base leading-7 text-slate-600">
          <li>Kompletní analýzu všech textů napříč vašimi články, stránkami nebo e-shopovými produkty.</li>
          <li>Hromadnou opravu diakritiky, překlepů a základních jazykových chyb v celé databázi.</li>
          <li>Chytrou úpravu slovosledu tam, kde původní text působí zmateně nebo zjevně strojově.</li>
          <li>Konzistentní sjednocení stylu komunikace přesně podle identity vaší značky.</li>
        </ul>
      </article>
      <article class="card-shell p-6">
        <h2 class="text-2xl font-semibold text-slate-900">Proč zvolit toto řešení</h2>
        <ul class="mt-5 space-y-4 text-base leading-7 text-slate-600">
          <li>Jednorázová práce zcela bez závazků a bez průběžných licenčních poplatků.</li>
          <li>Transparentní cenotvorba odvozená čistě podle skutečného počtu zpracovaných stránek či produktů.</li>
          <li>Veškeré výpočetní výkony AI a potřebné licence jsou již plně započítané v ceně.</li>
          <li>Extrémně rychlé dodání hotové databáze obratem po převzetí přístupů a odsouhlasení rozsahu.</li>
        </ul>
      </article>
    </div>
  </section>

  <ServiceOrderForm serviceName="Oprava diakritiky" sourcePage={pageUrl} />

  <section class="section-shell">
    <div class="container-shell">
      <SectionHeading
        eyebrow="FAQ"
        title="Časté otázky"
        description="Před objednávkou je dobré vědět, jak se služba počítá a jak přesně probíhá předání dat k opravě."
      />
      <div class="mt-10 space-y-4">
        {faq.map((item) => (
          <details class="card-shell p-6">
            <summary class="cursor-pointer list-none text-lg font-semibold text-slate-900">
              {item.question}
            </summary>
            <p class="mt-4 text-base leading-7 text-slate-600">{item.answer}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Potřebujete nejdřív odhadnout přesný rozsah webu?"
    description="Pošlete nám odkaz na web nebo orientační počet článků/produktů. Obratem zdarma doporučíme, jak celou opravu uchopit co nejefektivněji a kolik vás to bude stát."
    primaryHref="#objednavka"
    primaryLabel="Objednat službu"
    secondaryHref="/kontakt"
    secondaryLabel="Položit dotaz"
  />
</Layout>